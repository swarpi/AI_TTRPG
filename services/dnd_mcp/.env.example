# dnd_mcp environment configuration
# Copy this to .env and adjust values as needed.

# Transport configuration
MCP_HOST=0.0.0.0
MCP_PORT=8000

# OpenTelemetry (optional — set to emit to a collector instead of console)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=dnd-mcp

# Log level (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO
