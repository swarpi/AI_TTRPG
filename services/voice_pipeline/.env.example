# ── WebRTC Transport ──────────────────────────────────────────────────────────
# Sign up free at https://dashboard.daily.co
DAILY_API_KEY=

# Optional: pre-created room URL. If unset, bot creates an ephemeral room.
# DAILY_ROOM_URL=https://yourname.daily.co/your-room

# ── Speech-to-Text (Deepgram Nova-3) ──────────────────────────────────────────
# Sign up at https://console.deepgram.com
DEEPGRAM_API_KEY=

# ── Text-to-Speech (ElevenLabs) ───────────────────────────────────────────────
# Sign up at https://elevenlabs.io
ELEVENLABS_API_KEY=
# Voice ID — default is "Rachel". Browse voices at https://elevenlabs.io/voice-library
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── LLM Configuration ────────────────────────────────────────────────────────
# Select which provider to use: 'anthropic' or 'openai' (default: anthropic)
LLM_PROVIDER=anthropic

# Sign up at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Sign up at https://platform.openai.com
OPENAI_API_KEY=

# ── Log level ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Semantic Router (Ticket 2.2) ──────────────────────────────────────────────
# Start Redis Stack first: docker compose up -d redis
# Then seed: python seed_redis.py
REDIS_URL=redis://localhost:6379
